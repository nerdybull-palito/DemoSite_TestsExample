{
  "name": "demosite_testsexample",
  "version": "1.0.0",
  "description": "Playwright TypeScript tests for demo.nopcommerce.com",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:mobile": "playwright test --project=\"iphone 14\" --project=\"Pixel 5\"",
    "test:iphone": "playwright test --project=\"iPhone 14\"",
    "test:tablet": "playwright test --project=\"iPad Pro\"",
    "test:ui": "npx playwright test --ui",
    "report": "npx playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "typescript": "^5.9.3"
  },
  "directories": {
    "test": "tests"
  },
  "dependencies": {
    "playwright": "^1.58.2",
    "playwright-core": "^1.58.2",
    "undici-types": "^7.18.2"
  }
}
